# Pulse server config
PULSE_ADMIN_TOKEN=change-me-to-a-long-random-string
PULSE_DB_PATH=/data/pulse.sqlite
PULSE_LOG_LEVEL=INFO
PULSE_BIND_HOST=0.0.0.0
PULSE_BIND_PORT=8080

# Defaults pushed to agents (they can be overridden per-agent)
PULSE_DEFAULT_POLL_INTERVAL_S=5
PULSE_DEFAULT_PING_INTERVAL_S=5

# Data retention
PULSE_RAW_RETENTION_HOURS=48
PULSE_MINUTE_RETENTION_DAYS=14

# iperf3 orchestrator
PULSE_IPERF_PORT_MIN=42000
PULSE_IPERF_PORT_MAX=42099

# Alerting thresholds (percent loss and milliseconds)
PULSE_DOWN_LOSS_PCT=80
PULSE_DEGRADED_LOSS_PCT=20
PULSE_DEGRADED_RTT_P95_MS=500
PULSE_MIN_DWELL_S=60
PULSE_RECOVERY_WINDOW_S=120

# Ruckus One (optional — required only for the Attenuator tool)
PULSE_RUCKUS_REGION=na
PULSE_RUCKUS_TENANT_ID=
PULSE_RUCKUS_CLIENT_ID=
PULSE_RUCKUS_CLIENT_SECRET=
PULSE_RUCKUS_VENUE_ID=
